# ==============================================
# MeowTea Fresh AI Chatbot - Environment Config
# Copy file này thành .env và điền giá trị thật
# ==============================================

# --- Gemini AI ---
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-20b


# --- Supabase ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# --- PHP Backend (XAMPP) ---
# Base URL của PHP project (không có dấu / cuối)
PHP_BASE_URL=http://localhost/beverage_ordering_NORAG

# --- FastAPI Service ---
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=true

# --- MySQL (dùng để sync embeddings) ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=meowtea_schema

# --- Security ---
# Secret key để verify request từ PHP proxy
CHATBOT_SECRET_KEY=your_secret_key_here
